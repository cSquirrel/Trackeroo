{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trackeroo",
  "version": "0.2.0",
  "identifier": "com.trackeroo.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Trackeroo",
        "width": 1200,
        "height": 800,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/trackeroo-backend", "binaries/trackeroo-mcp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxRDE0RkRCRUREQjcwMjMKUldRamNOdnQyMC9SUVFtVlFvV0cyZThTazlWWkFMc1BFZGo0dmYwZ0s5RTI0Uzh0SGdlLy9JS3YK",
      "endpoints": [
        "https://github.com/cSquirrel/Trackeroo/releases/latest/download/latest.json"
      ]
    }
  }
}
